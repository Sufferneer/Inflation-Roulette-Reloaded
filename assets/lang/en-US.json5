{
	// Translation File
	// Language: English (US)
	
	// Comments are prefixed with two slashes (//) before each LINE, and will not be recognized by the game.
	// Comments are reserved for translation notes, either to clarify context or give instructions.
	// There's no need to translate comments.
	
	// Empty lines will also be ignored as well.
	
	// For the majority of the text in the game UI, a technical tone is used.
	// Unless specified otherwise, most lengthy prompts uses a witty/humorous tone.
	// Some jokes may be regional and lose its punchline. In this case, try come up with a similar joke
	// that works in your country's region. If all else fails, just make an entirely different joke.
	
	// In all cases, try your best to capture the original tone of the locale strings.
	// But if the language you're translating is inherently unserious (e.g. LOLCAT, Pirate Speak), ehh just get the message across.
	// Ultimately, the message that came across should remain unchanged to avoid any confusion.
	
	// For names of people and places, they should remain untranslated.
	// If your language uses another script other than Latin, make sure they phonetically
	// sound similar to its English counterpart.
	// In a nutshell, transliterate names.
	
	// For terms like "Inflation Roulette" and "Reloaded" used in a naming context,
	// unless your language does not use the Latin script, it should be remain
	// untranslated.
	
	// Valid Escape Sequences:
	// \n: New line
	// \s: Whitespace
	// The positions of escape sequences in-between sentences should be left AS IS.
	
	// Remember the "Transliterate Names" rule
	"game.title": "Inflation Roulette: Reloaded",
	"game.titleShort": "Inflation Roulette",
	"game.acronym": "IRR",
	
	// Version Formatting
	// For example, if the version is 2.3.1 in an Linux environment,
	// it will be formatted in the following way in the bottom info text of the Main Menu:
	
	// Inflation Roulette: Reloaded
	// Patch of Creativity (Pitstop 3 Amendment 1)
	// Version 2.3.1
	// Linux Build
	
	"game.version.numeral.format": "Version %1",
	"game.version.numeralModded.format": "Modded Version %1",
	"game.version.name.minor.format": "Pitstop %1",
	"game.version.name.hotfix.format": "Hotfix %1",
	// %1 is the platform in which the executable is dedicated.
	// For example, if the game is on Windows, "Windows Build" will be displayed.
	// Note that platform names will remain untranslated.
	"game.build.format": "%1 Build",
	
	"game.version.name.major.0": "Indev",
	// Version 1: Initial Release
	"game.version.name.major.1": "Initial Release",
	// Version 2: Added Achievements, Modding Tools, More Characters, Gallery & Jukebox and Results Screen
	// The Version Name has two interpretations. One being it being a update that introduces creative-related content (e.g. Modding Tools, Extras).
	// Another way to interpret this is the update being a piece of cloth, which is usually associated with creativity, suiting the update content.
	// If applicable, try to come up with some clever word-play or multi-interpreting phrases.
	"game.version.name.major.2": "Patch of Creativity",
	// Version 3: Added Android support and quality of life features.
	"game.version.name.major.3": "A Lil' Something Portable",
	// Yes. I'm using Greek letters for stylistic purposes (even tho it looks kinda offensive lmao)
	"game.version.name.state.a": "Public Alphα %1",
	"game.version.name.state.b": "Public βeta %1",
	"game.version.name.state.c": "Release Candidate %1",
	
	// These are the button texts in the Main Menu.
	"mainMenu.play": "Play",
	"mainMenu.achievements": "Achievements",
	"mainMenu.options": "Options",
	"mainMenu.language": "Language",
	"mainMenu.addons": "Add-Ons",
	// Utilities means Modding Utilities
	"mainMenu.utilities": "Utilities",
	"mainMenu.extras": "Extras",
	"mainMenu.donate": "Donate",
	
	// Tooltips for buttons in the Main Menu.
	"mainMenu.donate.tooltip": "Your generous donations help contribute to more games!",
	
	// When clicking on the Main Menu icon, a tally counter will be incremented. Get 10000 results in an achievement.
	"mainMenu.dongs": "You have accumulated:\n%1 Dongs",
	"mainMenu.dongs.comment.10": "ok you can stop doing that",
	"mainMenu.dongs.comment.20": "dont you have anything better to do",
	"mainMenu.dongs.comment.50": "go away now, play the stupid game",
	"mainMenu.dongs.comment.100": "dude are you okay? are you crazy?",
	"mainMenu.dongs.comment.200": "two hundred bro. get a job or something",
	"mainMenu.dongs.comment.300": "ya know, there's a person that made this",
	"mainMenu.dongs.comment.320": "typing out the code, debugging like hell",
	"mainMenu.dongs.comment.340": "painstakingly drawing all the characters",
	"mainMenu.dongs.comment.360": "designing the stupid ui",
	"mainMenu.dongs.comment.380": "... are you even listening to me",
	"mainMenu.dongs.comment.400": "stop wasting yo energy",
	"mainMenu.dongs.comment.500": "okay, no more, like, seriously",
	"mainMenu.dongs.comment.600": "lil bro just click \"play\" it aint that hard",
	"mainMenu.dongs.comment.700": "place yo mouse there, play the stupid game",
	"mainMenu.dongs.comment.800": "is it that hard to play the stupid game",
	"mainMenu.dongs.comment.900": "you know what i aint gonna talk to you anymore",
	"mainMenu.dongs.comment.1000": "...still clicking on that thing?",
	"mainMenu.dongs.comment.1100": "you know this gets you nothing, right",
	"mainMenu.dongs.comment.1200": "stop wasting your time, as if you're gonna get it back anyway",
	"mainMenu.dongs.comment.1300": "you know this game logs your exact latitude and longitude right",
	"mainMenu.dongs.comment.1400": "if you dont stop, your exact location will be sent to our servers",
	"mainMenu.dongs.comment.1500": "your location is currently being monitored by the devs.",
	"mainMenu.dongs.comment.2000": "oh my god you are not stopping",
	"mainMenu.dongs.comment.3000": "you're just that bored aint you",
	"mainMenu.dongs.comment.5000": "at 10000 dongs, your save data will be erased, and the game will delete itself.",
	"mainMenu.dongs.comment.10000": "ok fine here's your achievement. now get the hell out of my sight.",
	
