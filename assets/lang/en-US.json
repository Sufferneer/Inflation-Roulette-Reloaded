	"achievement.pressurizeYourself.name": "Backfire",
	"achievement.pressurizeYourself.description": "Get a taste of your own Pressurized medicine. Intentional or mere misfortune?",
	// Get a P Rank, AKA the maximum score.
	"achievement.maximumScore.name": "Pain of Perfectionism",
	"achievement.maximumScore.description": "Well done. You have played a perfect game, and what did that cost you.",
	// Get the lowest score possible.
	"achievement.minimumScore.name": "Strategized Loss",
	"achievement.minimumScore.description": "It's like you didn't even try, but in a closer glance it looks like you did - to LOSE?",
	// Win in all game modes at least once.
	"achievement.allGameModeWins.name": "Full Tour",
	"achievement.allGameModeWins.description": "A badge of dedication and unproductivity.",
	// Win as all vanilla characters at least once.
	"achievement.allCharacterWins.name": "All My Fellas",
	"achievement.allCharacterWins.description": "Looks like you really have no special preference for these vessels.",
	// Find all Easter Egg Startups.
	"achievement.allEasterEggs.name": "Attention Deficit",
	"achievement.allEasterEggs.description": "The archaic glyphs lie veiled, save by file digging, or code scouring.",
	// Accumulate 10000 Dongs in the Main Menu.
	"achievement.noLife.name": "Absolutely Jobless",
	"achievement.noLife.description": "Waste your life away for no reason. You have been branded, marked permanently.",
	"achievement.rarePolarizeSuccess.name": "Reverse Russian Roulette",
	"achievement.rarePolarizeSuccess.description": "You know this skill is risky, especially when it's a fresh batch of bullets, but miraculously you made it work.",
	// Use Polarize when there are 6 bullets in the chamber, and not inflate yourself.
	"achievement.eliminateByAssault.name": "Quick Draw",
	"achievement.eliminateByAssault.description": "A person on the verge of defeat must be dealt with swiftly... using a more direct method.",
	// Eliminate a player via Assault.
	"achievement.intentionalLoseByPolarize.name": "Lovesick",
	"achievement.intentionalLoseByPolarize.description": "You know you're safe; you know you're at your limit; you know it's gonna make you lose; yet you still put yourself in danger? You horny or something?",
	// Eliminate yourself after using Reveal and Polarize.
	"achievement.findCameraman.name": "Lights, Camera, Action!",
	"achievement.findCameraman.description": "Have you seen the cameraman?",
	// Meet Cobalt. (1/128 probability)
	"achievement.winByYourself.name": "Forever Alone",
	"achievement.winByYourself.description": "\"If you know yourself, you need not fear the result of a hundred battles.\" - The Art of War, probably.",
	// Win a game against yourself (All players are human and only one player uses a skill)
	"achievement.winAgainstStrategicCPUs.name": "Mind Games",
	"achievement.winAgainstStrategicCPUs.description": "Not gonna lie the bots aren't very smart either, but seeing everyone raging over these freaks, nice job.",
	// Win a game with every CPU set to their highest skill level.
	"achievement.nineTwentyOne.name": "9 Deaths with 21 Injured",
	"achievement.nineTwentyOne.description": "You seein' this? That's the type of image that gets worse when you see 'em.",
	// Play at exactly 9:21 PM, a random stupid image will flash on-screen briefly.
	"achievement.exportCharacterProject.name": "Utilizer",
	"achievement.exportCharacterProject.description": "Construct your own vessel using the Migrational Order Directive utility program.",
	// Export your first character creator project.
	"achievement.liveShots.name": "Not Enough Air",
	"achievement.liveShots.description": "A single .357 Magnum bullet costs about 15¢ to make, but retail prices ranges from 60¢ to $1.40. Now imagine firing 100 of them.",
	// Get shot 600 times with a blank round.
	"achievement.twoPlayers.name": "Stand-Off",
	"achievement.twoPlayers.description": "Two idiots, one gun. Who would survive? Answer: The manager.",
	// Set player count to 2 and win.
	"achievement.sixPlayers.name": "Hextuple Havoc",
	"achievement.sixPlayers.description": "That's what kids these days call 6's? Might as well call it circlejerking at this point.",
	// Set player count to 6 and win.
	"achievement.allFillerWins.name": "A Balanced Diet",
	"achievement.allFillerWins.description": "Experience every single method of torture, and keep yourself intact every time.",
	// Win as every filler. (Air, Water, Soda, Slime, Berry)

