<?xml version="1.0" encoding="utf-8"?>
<project>
	<!-- _________________________ Application Settings _________________________ -->
	<app file="Inflation-Roulette" title="Inflation Roulette: Reloaded" version="3.0.0" package="com.nicklysuffer.inflationroulette" packageName="com.nicklysuffer.inflationroulette" main="Main" company="NicklySuffer" />

	<set name="versionState" value="a.3" />
	<haxedef name="versionState" value="${versionState}" />

	<section if="android">
		<architecture name="arm64"/>
		<haxelib name="extension-androidtools"/>
		<template path="templates/android"/>
		<config:android mininum-sdk-version="21"/>
		<config:android target-sdk-version="31"/>
		<config:android permission="android.permission.MANAGE_EXTERNAL_STORAGE"/>
		<config:android attribute="android:requestLegacyExternalStorage=&quot;true&quot;"/>
		<config:android layoutInDisplayCutoutMode="shortEdges" />
		<config:android>
			<gradle-properties org.gradle.jvmargs="-Xmx4096m -XX:MaxMetaspaceSize=512m" />
			<application
				android:icon="@mipmap/ic_launcher"
				android:hasFragileUserData="true"
			/>
			<activity android:label="IR: Reloaded"/>
		</config:android>
		<dependency name="android.packagingOptions" value="
			packagingOptions {
				pickFirst 'lib/x86/libc++_shared.so'
				pickFirst 'lib/x86_64/libc++_shared.so'
				pickFirst 'lib/armeabi-v7a/libc++_shared.so'
				pickFirst 'lib/arm64-v8a/libc++_shared.so'
			}
		" />
		<certificate
			path="key.keystore"
			alias="inflation-roulette-reloaded"
			password="beAGoodFriend123"
			alias-password="beAGoodFriend123"
		/>
	</section>

	<!--The HaxeFlixel preloader is not accurate in Chrome. You can use it regularly if you embed the swf into a html file
		or you can set the actual size of your file manually at "FlxPreloaderBase-onUpdate-bytesTotal"-->
	<!-- <app preloader="Preloader" resizable="true" /> -->
	<app preloader="states.WebPreloadState" />

	<!-- ____________________________ Window Settings ___________________________ -->

	<!--These window settings apply to all targets-->
	<window width="1280" height="720" background="#000000" hardware="true" vsync="false" allow-high-dpi="true"/>

	<!--HTML5-specific-->
	<window if="html5" resizable="true" />

	<!--Desktop-specific-->
	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" vsync="false"/>

	<!--Mobile-specific-->
	<window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0" resizable="false"/>

	<!--Switch-specific-->
	<window if="switch" orientation="landscape" fullscreen="true" width="0" height="0" resizable="true" />

	<!-- _____________________________ Path Settings ____________________________ -->

	<set name="BUILD_DIR" value="export/debug" if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />
	<set name="BUILD_DIR" value="export/32bit" if="32bit" />

    <classpath name="source" path="source"/>

	<!-- __________________________ Game Assets & Etc. __________________________ -->
	
	<define name="_ALLOW_CRASH_HANDLER"/>
	<section if="_OFFICIAL_BUILD">
		<define name="_CHECK_FOR_UPDATES" if="desktop"/>
		<define name="_ALLOW_ADDONS" unless="web" />
		<define name="_ALLOW_UTILITIES" if="desktop" />
		<define name="_ALLOW_FILE_CREATION" if="_ALLOW_UTILITIES" />
		<define name="_ALLOW_SAVE_EXPORTING" if="mobile" />
		<define name="_ALLOW_EASTER_EGGS"/>
	</section>
	<define name="_USE_MP3" if="web"/>
	<define name="_BUILD_IN_ADDONS" unless="desktop" />

	<!-- Preload Assets -->

	<assets path="assets" exclude="*.mp3" unless="_USE_MP3" preload="true"/>
	<assets path="assets" exclude="*.ogg" if="_USE_MP3" preload="true"/>
    <section if="_ALLOW_ADDONS">
		<assets path='addons' unless="_BUILD_IN_ADDONS"/>
    </section>
    <section if="_ALLOW_UTILITIES">
		<assets path='projects'/>
		<assets path='conditionalAssets/ALLOW_UTILITIES' rename='assets' preload="true"/>
	</section>
	<section if="_BUILD_IN_ADDONS">
		<assets path='addons/Example Addon' rename='assets' preload="true"/>
		<assets path='conditionalAssets/BUILD_IN_ADDONS' rename='assets' exclude="*.ogg" if="_USE_MP3" preload="true"/>
		<assets path='conditionalAssets/BUILD_IN_ADDONS' rename='assets' exclude="*.mp3" unless="_USE_MP3" preload="true"/>
	</section>
	<assets path='conditionalAssets/NOT_BUILD_IN_ADDONS' unless="_BUILD_IN_ADDONS" rename='assets' preload="true"/>
	<section if="_ALLOW_EASTER_EGGS">
		<assets path="conditionalAssets/ALLOW_EASTER_EGGS" exclude="*.ogg" rename='assets' if="_USE_MP3" preload="true" embed="true"/>
		<assets path="conditionalAssets/ALLOW_EASTER_EGGS" exclude="*.mp3" rename='assets' unless="_USE_MP3" preload="true" embed="true"/>
	</section>
	<assets path="conditionalAssets/embed" exclude="*.ogg" rename='assets' if="_USE_MP3" preload="true" embed="true"/>
	<assets path="conditionalAssets/embed" exclude="*.mp3" rename='assets' unless="_USE_MP3" preload="true" embed="true"/>
    <assets path='dev/readme.txt' rename="readme.txt"/>

	<!-- _______________________________ Libraries ______________________________ -->

	<haxelib name="flixel" />
	<haxelib name="flixel-ui" />
	<haxelib name="flixel-addons" />
	<haxelib name="flixel-tools" />

	<haxelib name="tjson" />
	<haxelib name="hre" />

	<!--Fixes hxvlc using global rather than local. you will need to use hmm / hxpkg to compile this project though-->
	<setenv name="HAXEPATH" value="./"/>
	<haxelib name="hxvlc" />

	<!-- Enables a terminal log prompt on debug builds -->
	<haxelib name="hxcpp-debug-server" if="debug"/>
	
	<!-- ______________________________ Haxedefines _____________________________ -->

	<!--Enable the Flixel core recording system-->
	<!--<haxedef name="FLX_RECORD" />-->

	<!--Disable the native cursor API on Flash-->
	<!--<haxedef name="FLX_NO_NATIVE_CURSOR" />-->

	<!--Optimize inputs, be careful you will get null errors if you don't use conditionals in your game-->
	<!-- <haxedef name="FLX_NO_MOUSE" if="mobile" /> -->
	<!-- <haxedef name="FLX_NO_KEYBOARD" if="mobile" /> -->
	<!-- <haxedef name="FLX_NO_TOUCH" if="desktop" /> -->
	<!--<haxedef name="FLX_NO_GAMEPAD" />-->

	<!--Disable the Flixel core sound tray-->
	<!--<haxedef name="FLX_NO_SOUND_TRAY" />-->

	<!--Disable the Flixel core focus lost screen-->
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
	
	<!-- Show debug traces for hxCodec -->
	<haxedef name="HXC_DEBUG_TRACE" if="debug" />
	
	<!--Disable the Flixel core debugger. Automatically gets set whenever you compile in release mode!-->
	<haxedef name="FLX_NO_DEBUG" unless="debug" />

	<haxedef name="HXCPP_CHECK_POINTER" if="_ALLOW_CRASH_HANDLER" />
	<haxedef name="HXCPP_STACK_LINE"/>
	<haxedef name="HXCPP_STACK_TRACE"/>
	<haxedef name='no-deprecation-warnings' />
	
	<!--Macro fixes-->
	<haxeflag name="--macro" value="allowPackage('flash')" />
	<haxeflag name="--macro" value="include('my.pack')" />

	<!-- _________________________________ Custom _______________________________ -->

	<!--Place custom nodes like icons here (higher priority to override the HaxeFlixel icon)-->

	<icon path="dev/icon16.png" size='16'/>
	<icon path="dev/icon24.png" size='24'/>
	<icon path="dev/icon32.png" size='32'/>
	<icon path="dev/icon48.png" size='48'/>
	<icon path="dev/icon64.png" size='64'/>
	<icon path="dev/icon96.png" size='96'/>
	<icon path="dev/icon128.png" size='128'/>
	<icon path="dev/icon256.png" size='256'/>
	<assets path='dev/iconLinux.png' if="linux" unless="mobile" id="iconLinux" preload="true" embed="true"/>
</project>
